<screen>
  <panel width="fill" height="fill" layout="anchor">
    <panel width="500" height="auto" anchor_x="center" anchor_y="center"
           background="#1A1A2ECC" padding="16" direction="column"
           cross_align="center" gap="12" border_width="1" border_color="#444466FF">
      <label text="Controls" color="#FFFFFFFF" font_size="2"/>
      <label id="rebind_hint" text="Click a key to rebind" color="#888888FF"/>
      <scroll_view id="keybind_scroll" width="fill" height="380" scroll_bar_visible="true">
        <panel id="keybind_list" width="fill" height="auto" direction="column" gap="2"/>
      </scroll_view>
      <panel direction="row" gap="8">
        <button text="Reset Defaults" width="150" height="32"
                background="#553333FF" on_click="reset_keybinds" shadow="true"/>
        <button text="Done" width="150" height="32"
                background="#335588FF" on_click="close_controls" shadow="true"/>
      </panel>
    </panel>
  </panel>
</screen>
