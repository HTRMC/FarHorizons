<screen>
  <panel width="fill" height="fill" layout="anchor" background="#00000088">

    <!-- ======== Player panel (texture background) ======== -->
    <panel width="202" height="208" anchor_x="center" anchor_y="center"
           offset_x="-285" layout="anchor">
      <image id="inv_player_bg" src="inv:player_panel" width="202" height="208"/>

      <!-- Left armor slots: 4 rows, pitch 36 -->
      <panel id="armor_0" width="30" height="30" offset_x="18"  offset_y="18"/>
      <panel id="armor_1" width="30" height="30" offset_x="18"  offset_y="54"/>
      <panel id="armor_2" width="30" height="30" offset_x="18"  offset_y="90"/>
      <panel id="armor_3" width="30" height="30" offset_x="18"  offset_y="126"/>

      <!-- Right equipment slots: 4 rows, pitch 36 -->
      <panel id="equip_0" width="30" height="30" offset_x="156" offset_y="18"/>
      <panel id="equip_1" width="30" height="30" offset_x="156" offset_y="54"/>
      <panel id="equip_2" width="30" height="30" offset_x="156" offset_y="90"/>
      <panel id="equip_3" width="30" height="30" offset_x="156" offset_y="126"/>

      <!-- Player viewport (between slot columns) -->
      <panel id="player_viewport" width="96" height="138" offset_x="54" offset_y="18"/>

      <!-- Offhand slot (bottom center) -->
      <panel id="inv_offhand" width="30" height="30" offset_x="88" offset_y="162"/>
    </panel>

    <!-- ======== Inventory panel (texture background) ======== -->
    <panel width="352" height="220" anchor_x="center" anchor_y="center" layout="anchor">
      <image id="inv_bg" src="inv:inventory_bg" width="352" height="220"/>

      <!-- Header label -->
      <label text="INVENTORY" color="#CCCCCCE6" shadow="true" shadow_color="#000000AA"
             anchor_x="center" offset_y="2"/>

      <!-- Main inventory: 4 rows x 9 cols, slot pitch 36, 30x30 slots -->
      <panel id="inv_0"  width="30" height="30" offset_x="18"  offset_y="22"/>
      <panel id="inv_1"  width="30" height="30" offset_x="54"  offset_y="22"/>
      <panel id="inv_2"  width="30" height="30" offset_x="90"  offset_y="22"/>
      <panel id="inv_3"  width="30" height="30" offset_x="126" offset_y="22"/>
      <panel id="inv_4"  width="30" height="30" offset_x="162" offset_y="22"/>
      <panel id="inv_5"  width="30" height="30" offset_x="198" offset_y="22"/>
      <panel id="inv_6"  width="30" height="30" offset_x="234" offset_y="22"/>
      <panel id="inv_7"  width="30" height="30" offset_x="270" offset_y="22"/>
      <panel id="inv_8"  width="30" height="30" offset_x="306" offset_y="22"/>

      <panel id="inv_9"  width="30" height="30" offset_x="18"  offset_y="58"/>
      <panel id="inv_10" width="30" height="30" offset_x="54"  offset_y="58"/>
      <panel id="inv_11" width="30" height="30" offset_x="90"  offset_y="58"/>
      <panel id="inv_12" width="30" height="30" offset_x="126" offset_y="58"/>
      <panel id="inv_13" width="30" height="30" offset_x="162" offset_y="58"/>
      <panel id="inv_14" width="30" height="30" offset_x="198" offset_y="58"/>
      <panel id="inv_15" width="30" height="30" offset_x="234" offset_y="58"/>
      <panel id="inv_16" width="30" height="30" offset_x="270" offset_y="58"/>
      <panel id="inv_17" width="30" height="30" offset_x="306" offset_y="58"/>

      <panel id="inv_18" width="30" height="30" offset_x="18"  offset_y="94"/>
      <panel id="inv_19" width="30" height="30" offset_x="54"  offset_y="94"/>
      <panel id="inv_20" width="30" height="30" offset_x="90"  offset_y="94"/>
      <panel id="inv_21" width="30" height="30" offset_x="126" offset_y="94"/>
      <panel id="inv_22" width="30" height="30" offset_x="162" offset_y="94"/>
      <panel id="inv_23" width="30" height="30" offset_x="198" offset_y="94"/>
      <panel id="inv_24" width="30" height="30" offset_x="234" offset_y="94"/>
      <panel id="inv_25" width="30" height="30" offset_x="270" offset_y="94"/>
