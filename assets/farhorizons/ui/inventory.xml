      <panel id="inv_18" width="45" height="45" offset_x="27"  offset_y="141"/>
      <panel id="inv_19" width="45" height="45" offset_x="81"  offset_y="141"/>
      <panel id="inv_20" width="45" height="45" offset_x="135" offset_y="141"/>
      <panel id="inv_21" width="45" height="45" offset_x="189" offset_y="141"/>
