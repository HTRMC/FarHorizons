      <panel id="inv_12" width="45" height="45" offset_x="189" offset_y="87"/>
      <panel id="inv_13" width="45" height="45" offset_x="243" offset_y="87"/>
      <panel id="inv_14" width="45" height="45" offset_x="297" offset_y="87"/>
      <panel id="inv_15" width="45" height="45" offset_x="351" offset_y="87"/>
      <panel id="inv_16" width="45" height="45" offset_x="405" offset_y="87"/>
