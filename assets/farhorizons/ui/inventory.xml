<screen>
  <panel width="fill" height="fill" layout="anchor" background="#00000088">

    <!-- ======== Player panel (texture background) ======== -->
    <panel width="303" height="312" anchor_x="center" anchor_y="center"
           offset_x="-428" layout="anchor">
      <image id="inv_player_bg" src="inv:player_panel" width="303" height="312"/>

      <!-- Left armor slots: 4 rows, pitch 54 -->
      <panel id="armor_0" width="45" height="45" offset_x="27"  offset_y="27"/>
      <panel id="armor_1" width="45" height="45" offset_x="27"  offset_y="81"/>
      <panel id="armor_2" width="45" height="45" offset_x="27"  offset_y="135"/>
      <panel id="armor_3" width="45" height="45" offset_x="27"  offset_y="189"/>

      <!-- Right equipment slots: 4 rows, pitch 54 -->
      <panel id="equip_0" width="45" height="45" offset_x="234" offset_y="27"/>
      <panel id="equip_1" width="45" height="45" offset_x="234" offset_y="81"/>
      <panel id="equip_2" width="45" height="45" offset_x="234" offset_y="135"/>
      <panel id="equip_3" width="45" height="45" offset_x="234" offset_y="189"/>

      <!-- Player viewport (between slot columns) -->
      <panel id="player_viewport" width="144" height="207" offset_x="81" offset_y="27"/>

      <!-- Offhand slot (bottom center) -->
      <panel id="inv_offhand" width="45" height="45" offset_x="132" offset_y="243"/>
    </panel>

    <!-- ======== Inventory panel (texture background) ======== -->
    <panel width="528" height="330" anchor_x="center" anchor_y="end" offset_y="-60" layout="anchor">
      <image id="inv_bg" src="inv:inventory_bg" width="528" height="330"/>

      <!-- Header label -->
      <label text="INVENTORY" color="#CCCCCCE6" shadow="true" shadow_color="#000000AA"
             anchor_x="center" offset_y="3"/>

      <!-- Main inventory: 4 rows x 9 cols, slot pitch 54, 45x45 slots -->
      <panel id="inv_0"  width="45" height="45" offset_x="27"  offset_y="33"/>
      <panel id="inv_1"  width="45" height="45" offset_x="81"  offset_y="33"/>
      <panel id="inv_2"  width="45" height="45" offset_x="135" offset_y="33"/>
      <panel id="inv_3"  width="45" height="45" offset_x="189" offset_y="33"/>
      <panel id="inv_4"  width="45" height="45" offset_x="243" offset_y="33"/>
      <panel id="inv_5"  width="45" height="45" offset_x="297" offset_y="33"/>
      <panel id="inv_6"  width="45" height="45" offset_x="351" offset_y="33"/>
      <panel id="inv_7"  width="45" height="45" offset_x="405" offset_y="33"/>
      <panel id="inv_8"  width="45" height="45" offset_x="459" offset_y="33"/>

      <panel id="inv_9"  width="45" height="45" offset_x="27"  offset_y="87"/>
      <panel id="inv_10" width="45" height="45" offset_x="81"  offset_y="87"/>
