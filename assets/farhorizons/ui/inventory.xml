<screen>
  <panel width="fill" height="fill" layout="anchor" background="#00000088">

    <!-- ======== Player panel (texture background) ======== -->
    <panel width="192" height="320" anchor_x="center" anchor_y="center"
           offset_x="-290" layout="anchor">
      <image id="inv_player_bg" src="inv:player_panel" width="192" height="320"/>

      <!-- Header label -->
      <label text="PLAYER" color="#CCCCDDFF" shadow="true" shadow_color="#000000AA"
             anchor_x="center" offset_y="4"/>

      <!-- Armor slots (positioned to match sprite at 2x) -->
      <panel id="armor_0" width="36" height="36" offset_x="6"  offset_y="40"/>
      <panel id="armor_2" width="36" height="36" offset_x="6"  offset_y="88"/>
      <panel id="armor_1" width="36" height="36" offset_x="150" offset_y="40"/>
      <panel id="armor_3" width="36" height="36" offset_x="150" offset_y="88"/>

      <!-- Player viewport -->
      <panel id="player_viewport" width="72" height="232" offset_x="60" offset_y="32"/>

      <!-- Offhand slot -->
      <panel id="inv_offhand" width="36" height="36" offset_x="78" offset_y="276"/>
    </panel>

    <!-- ======== Inventory panel (texture background) ======== -->
    <panel width="364" height="240" anchor_x="center" anchor_y="center" layout="anchor">
      <image id="inv_bg" src="inv:inventory_bg" width="364" height="240"/>

      <!-- Header label -->
      <label text="INVENTORY" color="#CCCCDDFF" shadow="true" shadow_color="#000000AA"
             anchor_x="center" offset_y="4"/>

      <!-- Main inventory: 4 rows x 9 cols, slot pitch 40, start at (2,26) -->
      <panel id="inv_0"  width="36" height="36" offset_x="2"   offset_y="26"/>
      <panel id="inv_1"  width="36" height="36" offset_x="42"  offset_y="26"/>
      <panel id="inv_2"  width="36" height="36" offset_x="82"  offset_y="26"/>
      <panel id="inv_3"  width="36" height="36" offset_x="122" offset_y="26"/>
      <panel id="inv_4"  width="36" height="36" offset_x="162" offset_y="26"/>
      <panel id="inv_5"  width="36" height="36" offset_x="202" offset_y="26"/>
      <panel id="inv_6"  width="36" height="36" offset_x="242" offset_y="26"/>
      <panel id="inv_7"  width="36" height="36" offset_x="282" offset_y="26"/>
      <panel id="inv_8"  width="36" height="36" offset_x="322" offset_y="26"/>

      <panel id="inv_9"  width="36" height="36" offset_x="2"   offset_y="66"/>
