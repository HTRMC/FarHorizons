      <!-- Hotbar row -->
      <panel id="hotbar_0" width="30" height="30" offset_x="18"  offset_y="174"/>
      <panel id="hotbar_1" width="30" height="30" offset_x="54"  offset_y="174"/>
      <panel id="hotbar_2" width="30" height="30" offset_x="90"  offset_y="174"/>
      <panel id="hotbar_3" width="30" height="30" offset_x="126" offset_y="174"/>
      <panel id="hotbar_4" width="30" height="30" offset_x="162" offset_y="174"/>
