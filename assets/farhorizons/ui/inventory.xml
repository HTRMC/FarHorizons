      <panel id="inv_14" width="36" height="36" offset_x="202" offset_y="66"/>
      <panel id="inv_15" width="36" height="36" offset_x="242" offset_y="66"/>
      <panel id="inv_16" width="36" height="36" offset_x="282" offset_y="66"/>
      <panel id="inv_17" width="36" height="36" offset_x="322" offset_y="66"/>

      <panel id="inv_18" width="36" height="36" offset_x="2"   offset_y="106"/>
      <panel id="inv_19" width="36" height="36" offset_x="42"  offset_y="106"/>
      <panel id="inv_20" width="36" height="36" offset_x="82"  offset_y="106"/>
      <panel id="inv_21" width="36" height="36" offset_x="122" offset_y="106"/>
