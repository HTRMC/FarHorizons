<screen passthrough="true">
  <panel width="fill" height="fill" layout="anchor">

    <!-- Crosshair: centered on screen (15x15 at 2x = 30x30) -->
    <image id="crosshair" src="hud:crosshair" blend="inverted"
           width="30" height="30" anchor_x="center" anchor_y="center"/>

    <!-- Hotbar container: bottom-center, flush at bottom (182x22 at 2.5x = 455x55) -->
    <panel width="455" height="55" layout="anchor"
           anchor_x="center" anchor_y="end">

      <!-- Hotbar background image -->
      <image id="hotbar_bg" src="hud:hotbar" width="455" height="55"/>

      <!-- Selection highlight (24x23 at 2.5x = 60x58), offset_x set by binder -->
      <image id="selection" src="hud:selection" width="60" height="58"
             offset_x="-2" offset_y="-2"/>

      <!-- 9 slot color panels: each 45x45, at slot pitch 50px, centered in 55px height -->
      <panel id="slot_0" width="45" height="45" offset_x="5"   offset_y="5">
        <label id="count_0" text="" color="#FFFFFFEE" anchor_x="end" anchor_y="end" shadow="true" shadow_color="#000000AA"/>
      </panel>
      <panel id="slot_1" width="45" height="45" offset_x="55"  offset_y="5">
        <label id="count_1" text="" color="#FFFFFFEE" anchor_x="end" anchor_y="end" shadow="true" shadow_color="#000000AA"/>
      </panel>
      <panel id="slot_2" width="45" height="45" offset_x="105" offset_y="5">
        <label id="count_2" text="" color="#FFFFFFEE" anchor_x="end" anchor_y="end" shadow="true" shadow_color="#000000AA"/>
      </panel>
      <panel id="slot_3" width="45" height="45" offset_x="155" offset_y="5">
        <label id="count_3" text="" color="#FFFFFFEE" anchor_x="end" anchor_y="end" shadow="true" shadow_color="#000000AA"/>
      </panel>
      <panel id="slot_4" width="45" height="45" offset_x="205" offset_y="5">
        <label id="count_4" text="" color="#FFFFFFEE" anchor_x="end" anchor_y="end" shadow="true" shadow_color="#000000AA"/>
      </panel>
      <panel id="slot_5" width="45" height="45" offset_x="255" offset_y="5">
        <label id="count_5" text="" color="#FFFFFFEE" anchor_x="end" anchor_y="end" shadow="true" shadow_color="#000000AA"/>
      </panel>
      <panel id="slot_6" width="45" height="45" offset_x="305" offset_y="5">
        <label id="count_6" text="" color="#FFFFFFEE" anchor_x="end" anchor_y="end" shadow="true" shadow_color="#000000AA"/>
      </panel>
      <panel id="slot_7" width="45" height="45" offset_x="355" offset_y="5">
        <label id="count_7" text="" color="#FFFFFFEE" anchor_x="end" anchor_y="end" shadow="true" shadow_color="#000000AA"/>
      </panel>
      <panel id="slot_8" width="45" height="45" offset_x="405" offset_y="5">
        <label id="count_8" text="" color="#FFFFFFEE" anchor_x="end" anchor_y="end" shadow="true" shadow_color="#000000AA"/>
      </panel>

      <!-- Offhand slot (29x24 at 2.5x = 73x60), left of hotbar -->
      <image id="offhand" src="hud:offhand" width="73" height="60"
             offset_x="-73" offset_y="-2"/>
    </panel>

    <!-- Health bar: left of center, above hotbar -->
    <progress_bar id="health_bar" width="182" height="9"
                  anchor_x="center" anchor_y="end" offset_x="-91" offset_y="-60"
                  fill_color="#CC3333FF" track_color="#33333399" visible="false"/>

    <!-- Air bar: right of center, above hotbar -->
    <progress_bar id="air_bar" width="182" height="9"
                  anchor_x="center" anchor_y="end" offset_x="91" offset_y="-60"
                  fill_color="#3399CCFF" track_color="#33333399" visible="false"/>

    <!-- Block name label: centered, above hotbar -->
    <label id="block_name" text="" color="#FFFFFFE6"
           anchor_x="center" anchor_y="end" offset_y="-76" visible="false"
           shadow="true" shadow_color="#000000AA"/>

  </panel>
</screen>
