<screen>
  <panel width="fill" height="fill" layout="anchor">
    <panel anchor_x="center" anchor_y="center" direction="column"
           cross_align="stretch" gap="16" width="400" height="auto"
           padding="24" background="#1A1A2ECC" border_width="1" border_color="#444466FF">
      <label text="Multiplayer" color="#FFFFFFFF" font_size="2"/>
      <label text="Server Address" color="#AAAAAAFF"/>
      <text_input id="server_address_input" placeholder="127.0.0.1:7777"
                  width="fill" height="32" max_len="64"/>
      <panel direction="row" gap="8" width="fill">
        <button text="Connect" width="fill" height="40" flex_grow="1"
                background="#338833FF" shadow="true" on_click="connect_to_server"/>
        <button text="Back" width="fill" height="40" flex_grow="1"
                background="#555555FF" shadow="true" on_click="back_to_title"/>
      </panel>
    </panel>
  </panel>
</screen>
