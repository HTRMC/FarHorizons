<screen>
  <panel width="fill" height="fill" layout="anchor">
    <panel anchor_x="center" anchor_y="center" direction="column"
           cross_align="stretch" gap="16" width="400" height="auto"
           padding="24" background="#1A1A2ECC" border_width="1" border_color="#444466FF">
      <label text="Edit World" color="#FFFFFFFF" font_size="2"/>
      <label id="edit_world_name_label" text="" color="#AAAAAAFF"/>
      <label text="Game Mode" color="#AAAAAAFF"/>
      <button width="fill" height="36" background="#444466FF" shadow="true"
              on_click="edit_toggle_game_mode" justify="center">
        <label id="edit_game_mode_label" text="Game Mode: Creative" color="#FFFFFFFF"/>
      </button>
      <panel direction="row" gap="8" width="fill">
        <button text="Save" width="fill" height="40" flex_grow="1"
                background="#338833FF" shadow="true" on_click="confirm_edit_world"/>
        <button text="Cancel" width="fill" height="40" flex_grow="1"
                background="#555555FF" shadow="true" on_click="cancel_edit_world"/>
      </panel>
    </panel>
  </panel>
</screen>
